{
  "name": "personal-website",
  "type": "module",
  "version": "2.12.2",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "pagefind": "npx -y pagefind --site dist/client",
    "build:ci": "npm run build && npm run pagefind && npm run generate-pdf:ci",
    "preview": "astro preview --host",
    "generate-pdf": "node ./scripts/generate-pdf.js",
    "generate-pdf:ci": "start-server-and-test preview http://localhost:4321 generate-pdf",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.3",
    "@astrojs/node": "10.0.4",
    "@astrojs/preact": "5.1.1",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@tailwindcss/vite": "4.2.2",
    "astro": "6.1.5",
    "astro-expressive-code": "0.41.7",
    "preact": "10.29.1",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "sharp": "0.34.5",
    "tailwindcss": "4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@types/react": "19.2.14",
    "playwright": "1.59.1",
    "remark-capitalize-headings": "3.0.0",
    "start-server-and-test": "3.0.2"
  }
}
