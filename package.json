{
  "name": "personal-website",
  "type": "module",
  "version": "2.12.4",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "pagefind": "npx -y pagefind --site dist/client",
    "build:ci": "npm run build && npm run pagefind && npm run generate-pdf:ci",
    "preview": "astro preview --host",
    "generate-pdf": "node ./scripts/generate-pdf.js",
    "generate-pdf:ci": "start-server-and-test preview http://localhost:4321 generate-pdf",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "5.0.6",
    "@astrojs/node": "10.1.4",
    "@astrojs/preact": "5.1.5",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.3",
    "@tailwindcss/vite": "4.3.0",
    "astro": "6.4.6",
    "astro-expressive-code": "0.43.1",
    "preact": "10.29.2",
    "rehype-autolink-headings": "7.1.0",
    "rehype-external-links": "3.0.0",
    "sharp": "0.35.0",
    "tailwindcss": "4.3.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@types/react": "19.2.17",
    "playwright": "1.60.0",
    "remark-capitalize-headings": "3.0.0",
    "start-server-and-test": "3.0.10"
  }
}
